{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "scan",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-10",
	"observability": {
		"enabled": true
	},
	"compatibility_flags": [
		"nodejs_compat"
	],
	"kv_namespaces": [
		{
			"binding": "CRAWL_KV",
			"id": "7d4baef9833343d194a61f633d058a16"
		}
	],
    "r2_buckets": [
    {
      "binding": "MY_BUCKET",
      "bucket_name": "webhook-data"
    }
  ]
}
